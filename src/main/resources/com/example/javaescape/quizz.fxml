<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.javaescape.quizzController"
            prefWidth="1200" prefHeight="800"
            styleClass="@menu.css">


    <VBox spacing="20" alignment="TOP_CENTER" AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20">

        <!-- Question -->
        <Label fx:id="questionLabel"
               wrapText="true"
               style="-fx-font-size: 20px; -fx-font-weight: bold;"
               maxWidth="550"/>

        <!-- Boutons réponses -->
        <VBox spacing="10" alignment="CENTER">
            <Button fx:id="answerBtn1" prefWidth="300" style="-fx-font-size: 16px;"/>
            <Button fx:id="answerBtn2" prefWidth="300" style="-fx-font-size: 16px;"/>
            <Button fx:id="answerBtn3" prefWidth="300" style="-fx-font-size: 16px;"/>
            <Button fx:id="answerBtn4" prefWidth="300" style="-fx-font-size: 16px;"/>
        </VBox>

        <!-- Message correct/incorrect -->
        <Label fx:id="feedbackLabel"
               style="-fx-font-size: 18px; -fx-font-weight: bold;"
               visible="false"/>

        <!-- Bouton Next -->
        <Button fx:id="nextButton"
                text="Next"
                prefWidth="150"
                style="-fx-font-size: 16px;"
                visible="false"/>

        <Label fx:id="scoreLabel" text="0/5" layoutX="1050" layoutY="20" />
        <Label fx:id="questionCountLabel" text="0/20" layoutX="1050" layoutY="50" />


    </VBox>

</AnchorPane>